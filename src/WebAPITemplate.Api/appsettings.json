{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/system_log_.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": null,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "WebAPITemplate"
    }
  },
  "AppConfig": {
    "UseSwaggerProduction": "false",
    "ClientUrl": "https://typicode.com",
    "TimeOut": 30
  },
  "AllowedHosts": "*"
}